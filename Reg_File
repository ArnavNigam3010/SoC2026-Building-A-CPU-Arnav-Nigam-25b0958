module regfile(
    input        clk,
    input        we,
    input  [1:0] raddr0,
    input  [1:0] raddr1,
    input  [1:0] waddr,
    input  [7:0] wdata,
    output [7:0] rdata0,
    output [7:0] rdata1
);

    reg [7:0] rf [3:0];

    assign rdata0 = rf[raddr0];
    assign rdata1 = rf[raddr1];

    always @(posedge clk) begin
        if (we) begin
            rf[waddr] <= wdata;
        end
    end
endmodule
